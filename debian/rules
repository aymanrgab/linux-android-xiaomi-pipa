#!/usr/bin/make -f

include /usr/share/linux-packaging-snippets/kernel-snippet.mk

# Override dtbo.img rule to add AVB footer after building.
# Keeps the snippet's prerequisites (out/dtb-stamp), replaces the recipe
# to also run avbtool for verified boot compatibility.
out/KERNEL_OBJ/dtbo.img: $(CURDIR)/debian/avb-testkey.pem
	mkdtboimg cfg_create $@ $(KERNEL_IMAGE_DTB_OVERLAY_CONFIGURATION) --dtb-dir $(KERNEL_OUT)/$(KERNEL_IMAGE_DTB_OVERLAY_DTB_DIRECTORY)
	avbtool add_hash_footer --image $@ \
		--partition_name dtbo \
		--partition_size 33554432 \
		--algorithm SHA256_RSA2048 \
		--key $(CURDIR)/debian/avb-testkey.pem

$(CURDIR)/debian/avb-testkey.pem:
	openssl genrsa -out $@ 2048 2>/dev/null

%:
	dh $@
