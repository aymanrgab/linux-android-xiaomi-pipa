#
# Droidian / Halium required kernel config for Xiaomi Pad 6 (pipa)
# Based on: https://github.com/Halium/halium-scripts/blob/master/check-kernel-config
#
# Enable with: ./scripts/kconfig/merge_config.sh -m .config droidian.config
#

# --- Namespaces (required for LXC) ---
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# --- Cgroups (required for LXC + systemd) ---
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_NET_PRIO=y
CONFIG_CGROUP_BPF=y
CONFIG_CPUSETS=y
CONFIG_PROC_PID_CPUSET=y
CONFIG_CGROUP_PIDS=y
CONFIG_MEMCG=y

# --- systemd requirements ---
CONFIG_FHANDLE=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_DMIID=y
CONFIG_AUTOFS4_FS=y

# --- Security ---
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y

# --- VT / TTY (required for Phosh framebuffer) ---
CONFIG_VT=y
CONFIG_CONSOLE_TRANSPARENT=y
CONFIG_VT_CONSOLE=y
CONFIG_HW_CONSOLE=y
CONFIG_VT_HW_CONSOLE_BINDING=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y

# --- DRM / GPU (Adreno 650 / Qualcomm) ---
CONFIG_DRM=y
CONFIG_DRM_MSM=y
CONFIG_DRM_MSM_ADRENO_DEFAULT_GPMU=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_FBDEV_OVERALLOC=100

# --- IPC ---
CONFIG_POSIX_MQUEUE=y

# --- Network (for SSH/telnet debugging) ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y

# --- BPF (used by systemd + LXC) ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_NETFILTER_XT_MATCH_BPF=y

# --- Filesystem features ---
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XATTR=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_FUSE_FS=y
CONFIG_CUSE=y

# --- Android binders (for libhybris) ---
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"

# --- Android vendor dependencies ---
CONFIG_STAGING=y
CONFIG_ASHMEM=y
CONFIG_ION=y
CONFIG_ION_SYSTEM_HEAP=y
CONFIG_ION_CMA_HEAP=y

# --- Qualcomm-specific ---
CONFIG_QCOM_COMMON_DBGAUX=y
CONFIG_QCOM_GDSC=y
CONFIG_QCOM_RMTFS_MEM=y
CONFIG_QCOM_WDT=y

# --- Misc ---
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_RTC_CLASS=y
CONFIG_RTC_HCTOSYS=y
CONFIG_RTC_SYSTOHC=y
CONFIG_UNIX98_PTYS=y
CONFIG_DEVPTS_MULTIPLE_INSTANCES=y
CONFIG_FW_LOADER_USER_HELPER=y
CONFIG_FW_LOADER_USER_HELPER_FALLBACK=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_UINPUT=y

# --- Debugging (keep enabled during development) ---
CONFIG_DYNAMIC_DEBUG=y
CONFIG_DEBUG_FS=y
CONFIG_MAGIC_SYSRQ=y
CONFIG_PRINTK_TIME=y
